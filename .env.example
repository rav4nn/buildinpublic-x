# ── Twitter / X ────────────────────────────────────────────────────────────────
# Get these from https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret

# ── GitHub ──────────────────────────────────────────────────────────────────────
# Fine-grained PAT or classic token with repo:read scope
# In GitHub Actions this is provided automatically as secrets.GITHUB_TOKEN
GITHUB_TOKEN=your_github_token

# ── LLM Providers — add only the one you use ────────────────────────────────────
# Set llm_provider in config.yml to match your chosen key below.

# anthropic  →  claude-haiku-4-5-20251001  (default, cheapest)
ANTHROPIC_API_KEY=your_anthropic_api_key

# openai     →  gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key

# gemini     →  gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key

# deepseek   →  deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key

# groq       →  llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key
